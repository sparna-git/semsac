<!DOCTYPE html>
<html lang="fr">

<head>
  <meta charset="utf-8">
  <meta content="width=device-width, initial-scale=1.0" name="viewport">
  <title>{{ title }}</title>

  <link rel="icon" href="{{ "/fav.png" | relative(page) }}" type="image/png">

  <!-- Google Fonts -->
  <link href="https://fonts.googleapis.com/css?family=Montserrat:300,400,500,700|Open+Sans:300,300i,400,400i,700,700i" rel="stylesheet">

  <!-- Bootstrap CSS -->
  <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.2.3/dist/css/bootstrap.min.css" rel="stylesheet" integrity="sha384-rbsA2VBKQhggwzxH7pPCaAqO46MgnOM80zW1RWuH61DGLwZJEdK2Kadq2F9CUG65" crossorigin="anonymous">

  <!-- Font Awesome -->
  <link rel="stylesheet" href="{{ "/assets/fa/css/all.min.css" | relative(page) }}" />

  <!-- Template Main CSS File -->
  <link href="{{ "/assets/css/styles.css" | relative(page) }}" rel="stylesheet" />

  <!-- Custom CSS -->
  <style>
    #footer_content {
      display: block;
      width: 100%;
      margin: 0 auto;
      color: #ccc;
    }
    .footer-contact a { color: #fff; text-decoration: underline; }
    .footer-contact p { margin-bottom: 0.25rem; }
    /* Navbar site title */
    .site-title { font-family: 'Montserrat', sans-serif; font-weight:700; font-size:1.25rem; color:#111; line-height:1; }
    .site-baseline { font-family: 'Open Sans', sans-serif; font-size:0.75rem; color:#666; margin-top:0.1rem; display:block; }
    </style>
</head>

<body class="d-flex flex-column min-vh-100">

  <!-- Navbar -->
  <nav class="navbar navbar-expand-lg navbar-light" style="background-color: white; border-bottom: 1px solid #ccc;">
    <div class="container">
      <a class="navbar-brand d-flex flex-column me-3" href="{{ "/" | relative(page) }}">
        <span class="site-title">Semsac</span>
        <small class="site-baseline">Explorez le fonds des sacs à procès !</small>
      </a>
      <button class="navbar-toggler" type="button" data-bs-toggle="collapse" data-bs-target="#navbarSupportedContent" aria-controls="navbarSupportedContent" aria-expanded="false" aria-label="Toggle navigation">
        <span class="navbar-toggler-icon"></span>
      </button>
      <div class="collapse navbar-collapse" id="navbarSupportedContent">
        <ul class="navbar-nav me-auto mb-2 mb-lg-0">
          <li class="nav-item">
            <a class="nav-link" href="{{ "/" | relative(page) }}">Explorateur</a>
          </li>
          <li class="nav-item">
            <a class="nav-link" href="{{ "/formulaire/" | relative(page) }}">Formulaire</a>
          </li>
          <li class="nav-item">
            <a class="nav-link" href="{{ "/pages/projet/" | relative(page) }}">Le Projet</a>
          </li>
          <li class="nav-item">
            <a class="nav-link" href="{{ "/pages/modele/" | relative(page) }}">Le Modèle</a>
          </li>
          <li class="nav-item">
            <a class="nav-link" href="{{ "/pages/fonds/" | relative(page) }}">Le Fonds</a>
          </li>
        </ul>
      </div>
      <div class="d-flex align-items-center gap-2">
        <a href="https://archives.haute-garonne.fr/" target="_blank" rel="noopener">
          <img src="{{ "/assets/images/Logo_AD31_point.png" | relative(page) }}" alt="AD31" height="50">
        </a>
        <a href="https://www.haute-garonne.fr/" target="_blank" rel="noopener">
          <img src="{{ "/assets/images/Logo%20CD31.png" | relative(page) }}" alt="Conseil Départemental 31" height="50">
        </a>
      </div>
    </div>
  </nav>

  <main class="flex-grow-1">
    {{ content | safe }}
  </main>

  <!-- Footer -->
  <footer class="text-left py-4 mt-auto" style="background-color: #1d1d1b;">
    <div id="footer_content" class="container py-4">
      <div class="row align-items-center">
        <div class="col-12 col-md-3 text-center text-md-start mb-3 mb-md-0">
          <a
            href="https://www.haute-garonne.fr/"
            target="_blank"
            rel="noopener">
          <img src="{{ "/assets/images/CD-cartouche-AGIR-AVEC%20rvb.png" | relative(page) }}" alt="Conseil Départemental de la Haute-Garonne" style="height:80px;">
          </a>
        </div>

        <div class="col-12 col-md-4 text-white footer-contact">
          <h4 style="color:#fff; font-weight:400; margin-bottom:0.5rem;">Archives Départementales de la Haute-Garonne</h4>
          <p>11 boulevard Griffoul-Dorval<br>31400 Toulouse - France</p>
          <p>Tél : <a href="tel:+33534325000">+33 (0)5 34 32 50 00</a></p>
          <p>Adresse mail : <a href="mailto:archives@cd31.fr">archives@cd31.fr</a></p>
        </div>

        <div class="d-none d-md-block col-md-5"><!-- colonne vide pour espacement à droite --></div>
      </div>
    </div>
  </footer>

  <!-- Bootstrap JS -->
  <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.2.3/dist/js/bootstrap.bundle.min.js" integrity="sha384-kenU1KFdBIe4zVF0s0G1M5b4hcpxyD9F7jL+jjXkk+Q2h455rYXK/7HAuoJl+0I4" crossorigin="anonymous"></script>

</body>
</html>
