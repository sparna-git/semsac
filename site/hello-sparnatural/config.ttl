vocabulaire:li a skos:ConceptScheme;
  skos:notation "li";
  dct:coverage rico:Place;
  dct:isRequiredBy rico:hasOrHadPlaceType;
  dct:title "Types de lieux";
  dct:description "Thésaurus des types de lieux (entités géo-historiques). Saisi manuellement en se fondant sur les catégories de lieux sous-jacentes ou implicites dans les référentiels de lieux de la base de données des sacs à procès des Archives départementales de la Haute-Garonne. Des enrichissements, modifications de structure et alignements sont prévus dans les prochains mois. Nombre de concepts : 39.";
  dct:creator "Archives départementales de la Haute-Garonne (France)";
  dct:hasVersion "1.0";
  dct:created "2025";
  dct:modified "2025";
  skos:prefLabel "Type de lieu"@fr;
  skos:hasTopConcept type:licom, type:licou, type:lidep, type:lilie, type:liqua, type:lireg,
    type:lisei, type:liabb, type:lianc, type:lican, type:licat, type:lichp, type:licha,
    type:liche, type:licol, type:lidom, type:liegl, type:liexp, type:lifau, type:lifor,
    type:lihop, type:lipre, type:livil, type:liimp, type:lilac, type:limon, type:limou,
    type:lipal, type:lipar, type:lipla, type:lipon, type:lipor, type:lipot, type:lipri,
    type:liprs, type:lipui, type:lirou, type:lirue .

